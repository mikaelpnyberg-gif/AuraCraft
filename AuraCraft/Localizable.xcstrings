{
  "sourceLanguage": "en",
  "strings": {
    "%lld": {
      "comment": "A badge displaying the number of lights in a room. The text inside the badge is the number of lights in the room.",
      "isCommentAutoGenerated": true
    },
    "%lld %@": {
      "comment": "A label displaying the count of a specific light capability, followed by the pluralized form of \"light\". The argument is the count of the light capability.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld %2$@"
          }
        }
      }
    },
    "%lld %@ · %lld %@": {
      "comment": "A subheading displaying the number of rooms and lights in the home. The first argument is the count of rooms in the home. The second argument is the count of lights in the home.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld %2$@ · %3$lld %4$@"
          }
        }
      }
    },
